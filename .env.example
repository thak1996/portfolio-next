# URL do Banco de Dados PostgreSQL
# Exemplo: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5433/portfolio_db?schema=public"

# Configurações de Autenticação Administrativa
# Gere um secret forte: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this"
ADMIN_USERNAME="your_admin_username"
ADMIN_PASSWORD="your_admin_password"

# Variáveis do Site (Opcional)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_RESUME_URL=
NEXT_PUBLIC_CONTACT_WHATSAPP=
NEXT_PUBLIC_CONTACT_LINKEDIN=
NEXT_PUBLIC_CONTACT_GITHUB=
